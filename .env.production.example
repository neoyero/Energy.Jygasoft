# =====================================================================
# energy-web — variables de PRODUCCIÓN (copiar a .env en el droplet).
# DATABASE_URL apunta al servicio "db" del docker-compose (misma red).
# =====================================================================

# App
NEXT_PUBLIC_SITE_URL=https://energy.jygasoft.com
NODE_ENV=production

# Postgres (servicio db del compose)
POSTGRES_USER=energy_app
POSTGRES_PASSWORD=CHANGEME_password_fuerte
POSTGRES_DB=energy_app
DATABASE_URL=postgres://energy_app:CHANGEME_password_fuerte@db:5432/energy_app

# n8n (saliente)
N8N_WEBHOOK_URL=https://n8n.jygasoft.com/webhook/energy-lead
N8N_HMAC_SECRET=CHANGEME_min_16
N8N_HMAC_KID=energy-web-v1

# Inbound desde n8n
WEBHOOK_INBOUND_SECRET=CHANGEME_min_16

# Asistente IA (Gemini)
GEMINI_API_KEY=CHANGEME
GEMINI_MODEL=gemini-2.5-flash

# Meta
META_PIXEL_ID=CHANGEME
META_CAPI_TOKEN=CHANGEME
NEXT_PUBLIC_META_PIXEL_ID=CHANGEME

# Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADp3gzU_grDWZ3WP
TURNSTILE_SECRET=0x4AAAAAADp3g0DQpjVgyPTn-LsPne63aQU

# Auth.js (genera AUTH_SECRET con: openssl rand -base64 32) — OBLIGATORIO en prod
AUTH_SECRET=CHANGEME_base64_32
AUTH_URL=https://energy.jygasoft.com

# je-admin — correo OTP vía Microsoft 365 / Graph (App Registration + Mail.Send)
M365_TENANT_ID=CHANGEME
M365_CLIENT_ID=CHANGEME
M365_CLIENT_SECRET=CHANGEME
M365_SENDER=no-reply@jygasoft.com

# je-admin — login por código (OTP)
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_REQUESTS_PER_EMAIL=3
