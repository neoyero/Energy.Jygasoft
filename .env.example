# =====================================================================
# Jygasoft Energy — energy-web · variables de entorno
# Copia este archivo a `.env` y rellena los valores reales.
# Regla: SOLO las NEXT_PUBLIC_* llegan al navegador. El resto es server-only.
# =====================================================================

# --- App ---
NEXT_PUBLIC_SITE_URL=https://energy.jygasoft.com
NODE_ENV=production

# --- Base de datos (Fase 2) ---
# Postgres co-hosteado en el droplet de n8n vía docker-compose (servicio "db", misma VPC).
DATABASE_URL=postgres://energy_app:CHANGEME@db:5432/energy_app

# --- n8n (Fase 3, saliente) ---
N8N_WEBHOOK_URL=https://n8n.jygasoft.com/webhook/energy-lead
N8N_HMAC_SECRET=CHANGEME_shared_hmac_secret_min_16_chars
N8N_HMAC_KID=energy-web-v1

# --- Inbound desde n8n (Fase 7) ---
WEBHOOK_INBOUND_SECRET=CHANGEME_inbound_secret_min_16_chars

# --- Asistente IA (Gemini) ---
GEMINI_API_KEY=CHANGEME_google_ai_studio
GEMINI_MODEL=gemini-2.5-flash

# --- Meta Pixel + Conversions API (Fase 6) ---
META_PIXEL_ID=CHANGEME
META_CAPI_TOKEN=CHANGEME_server_only
NEXT_PUBLIC_META_PIXEL_ID=CHANGEME
# META_CAPI_TEST_EVENT_CODE=TEST12345

# --- Anti-spam Turnstile (Fase 3) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=CHANGEME
TURNSTILE_SECRET=CHANGEME_server_only

# --- Auth.js panel /admin (Fase 7) ---
AUTH_SECRET=CHANGEME_generar_con_openssl_rand_base64_32
AUTH_URL=https://energy.jygasoft.com

# --- Rate-limit (opcional; defaults 10 req / 60s por IP) ---
# RATE_LIMIT_MAX=10
# RATE_LIMIT_WINDOW_MS=60000
